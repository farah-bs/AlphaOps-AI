# PostgreSQL - Data
PGHOST=postgres_data
PGPORT=5432
PGDATABASE=nl2sql_db
PGUSER=
PGPASSWORD=

# PostgreSQL - Airflow
AIRFLOW_PGDATABASE=airflow_db
AIRFLOW_PGHOST=postgres_airflow
AIRFLOW_PGPORT=5432
AIRFLOW_PGUSER=
AIRFLOW_PGPASSWORD=

# Mistral API Key
MISTRAL_API_KEY=

# Agent IA — Email (Gmail example: create an App Password at myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=your-app-password
SMTP_FROM=your-address@gmail.com

# Agent IA — Security (shared between agent and serving containers)
HMAC_SECRET=change-me-to-a-random-secret

# Retraining threshold (number of feedback entries before retraining)
RETRAIN_K=20

# Public URL of the serving API (used in feedback email links — must be reachable from outside Docker)
# In production: https://your-domain.com/api
# Locally: http://localhost:8082
FEEDBACK_BASE_URL=http://localhost:8082

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
