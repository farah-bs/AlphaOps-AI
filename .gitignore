########################################
# ENVIRONMENTS
########################################
.env
.env.*
!.env.example

########################################
# PYTHON
########################################
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
build/
dist/

.venv/
venv/
env/

########################################
# AIRFLOW
########################################
# airflow/logs/ est un dossier runtime — on ignore son contenu mais on garde
# le .gitkeep pour que le dossier existe dès le clone (permissions Docker OK)
airflow/logs/*
!airflow/logs/.gitkeep
/logs/
airflow-webserver.pid
airflow.cfg
*.db

########################################
# DOCKER
########################################
docker-compose.override.yml
*.log
*.pid

########################################
# DÉPLOIEMENT / SÉCURITÉ
########################################
nginx/.htpasswd
nginx/ssl/
.env.prod

########################################
# POSTGRES / DATA
########################################
pgdata_*/
*.dump

########################################
# ML ARTIFACTS
# Le dossier artifacts/ est un dossier runtime généré par le training.
# Il n'est PAS versionné — uniquement le .gitkeep pour garantir l'existence
# du dossier lors d'un clone (volumes Docker + permissions correctes).
########################################
artifacts/*
!artifacts/.gitkeep

########################################
# MLFLOW
# Même logique : mlruns/ est runtime, on garde juste le .gitkeep.
########################################
mlruns/*
!mlruns/.gitkeep
ml/registry/REGISTRY.md

########################################
# DATA FILES (si CSV temporaires)
########################################
data/raw/
data/processed/*.csv
data/processed/*.parquet

########################################
# IDE
########################################
.vscode/
.idea/

########################################
# OS
########################################
.DS_Store
Thumbs.db

########################################
# CLAUDE / LLM LOGS
########################################
claude_logs/
CLAUDE.md
data/ref_data.csv
data/prod_data.csv
ml/features/features.txt
startup.txt
notes.txt
